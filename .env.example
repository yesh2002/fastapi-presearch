APP_NAME=presearch-doppelgange-proxy
DEBUG=false

# Fill these after inspecting network requests from doppelgange page
UPSTREAM_TEXT_URL=https://example.com/api/text-search
UPSTREAM_IMAGE_URL=https://example.com/api/image-search
UPSTREAM_TIMEOUT_SECONDS=20

# Optional auth headers if upstream requires login/cookie
UPSTREAM_AUTHORIZATION=
UPSTREAM_COOKIE=
UPSTREAM_ORIGIN=https://presearch.com
UPSTREAM_REFERER=https://presearch.com/doppelgange

DEFAULT_MODE=spicy
